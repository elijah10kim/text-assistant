# Claude API key — https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-actual-key

# Telegram bot token — from @BotFather
TELEGRAM_BOT_TOKEN=your-actual-bot-token

# Your Telegram user ID — from @userinfobot (only this user's messages are answered)
TELEGRAM_ALLOWED_USER_ID=your-actual-user-id

# Ignav API Key
IGNAV_API_KEY=your-actual-ignav-api-key